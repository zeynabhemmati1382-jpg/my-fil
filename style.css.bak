* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', 'Inter', system-ui, 'Vazirmatn', sans-serif;
}

body {
    background: #f7f5f2;
    padding: 20px;
    min-height: 100vh;
}

/* ساختار اصلی */
.app-wrapper {
    display: flex;
    gap: 24px;
    max-width: 1400px;
    margin: 0 auto;
}

/* سایدبار با تقویم */
.sidebar {
    width: 320px;
    background: white;
    border-radius: 32px;
    padding: 24px 20px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    height: fit-content;
    position: sticky;
    top: 20px;
}

.logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.4rem;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 2px solid #f0ebe4;
}

.logo i { color: #f5a623; }
.logo span { color: #f5a623; }

/* تقویم */
.calendar-card {
    background: #fefaf5;
    border-radius: 24px;
    padding: 16px;
    margin-bottom: 24px;
}

.calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
}

.calendar-header button {
    background: none;
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    color: #8b7a6b;
}

.calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    font-size: 0.8rem;
    color: #a18f7e;
    margin-bottom: 8px;
}

.calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
}

.calendar-day {
    text-align: center;
    padding: 8px 4px;
    font-size: 0.85rem;
    border-radius: 50%;
    cursor: pointer;
    transition: 0.1s;
}

.calendar-day:hover {
    background: #f0e7dc;
}

.calendar-day.today {
    background: #f5a623;
    color: white;
    font-weight: bold;
}

.calendar-day.has-task {
    position: relative;
}

.calendar-day.has-task::after {
    content: '';
    width: 4px;
    height: 4px;
    background: #f5a623;
    border-radius: 50%;
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
}

/* آمار سریع */
.quick-stats {
    display: flex;
    gap: 16px;
    justify-content: space-around;
    background: #fefaf5;
    border-radius: 24px;
    padding: 16px;
}

.stat {
    text-align: center;
}

.stat i {
    font-size: 1.4rem;
    color: #f5a623;
}

.stat span {
    display: block;
    font-size: 1.6rem;
    font-weight: bold;
    color: #2c3e4e;
}

/* بخش اصلی */
.main {
    flex: 1;
    background: white;
    border-radius: 32px;
    padding: 28px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.05);
}

.top-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 2px solid #f0ebe4;
}

.greeting h1 {
    font-size: 1.6rem;
    color: #2c3e4e;
}

.greeting p {
    color: #8b7a6b;
    font-size: 0.85rem;
}

.motivation-message {
    background: #fef3c7;
    padding: 10px 20px;
    border-radius: 60px;
    color: #b45309;
    font-weight: bold;
}

/* کارت افزودن کار */
.add-task-card {
    background: #fefaf5;
    border-radius: 28px;
    padding: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 28px;
}

.add-task-card input, .add-task-card select, .add-task-card button {
    padding: 12px 16px;
    border-radius: 60px;
    border: 1px solid #e6dfd6;
    background: white;
    font-size: 0.9rem;
}

.add-task-card input { flex: 2; }
.add-task-card select { flex: 1; }
.add-task-card input[type="date"] { flex: 1; }
.add-task-card button {
    background: #f5a623;
    color: white;
    border: none;
    cursor: pointer;
    font-weight: bold;
}

/* فیلتر */
.filter-section {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 24px;
}

#searchInput {
    flex: 2;
    padding: 10px 16px;
    border-radius: 40px;
    border: 1px solid #e6dfd6;
    background: #fefaf5;
}

.filter-buttons {
    display: flex;
    gap: 8px;
}
.filter-btn {
    padding: 8px 20px;
    border-radius: 40px;
    border: none;
    background: #f0ebe4;
    cursor: pointer;
    font-weight: 500;
}

.filter-btn.active {
    background: #f5a623;
    color: white;
}

/* لیست کارها */
.tasks-list h3 {
    margin-bottom: 16px;
    color: #2c3e4e;
}

.task-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-height: 500px;
    overflow-y: auto;
}

.task-item {
    background: white;
    border-radius: 20px;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-right: 6px solid;
    box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    transition: 0.2s;
}

.task-item:hover {
    transform: translateX(-4px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.08);
}

.task-info {
    flex: 1;
}

.task-title {
    font-weight: 600;
    font-size: 1rem;
}

.task-date {
    font-size: 0.7rem;
    color: #a18f7e;
    margin-top: 4px;
}

.completed-task .task-title {
    text-decoration: line-through;
    opacity: 0.6;
}

.task-actions {
    display: flex;
    gap: 8px;
}

.task-actions button {
    background: none;
    border: none;
    font-size: 1.1rem;
    cursor: pointer;
    padding: 6px;
    border-radius: 50%;
    transition: 0.1s;
}

.complete-btn { color: #4ade80; }
.edit-btn { color: #60a5fa; }
.delete-btn { color: #f87171; }

/* مودال */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    justify-content: center;
    align-items: center;
    z-index: 1000;
}

.modal-content {
    background: white;
    border-radius: 32px;
    padding: 28px;
    width: 400px;
    max-width: 90%;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px;
}

.close-modal {
    font-size: 1.5rem;
    cursor: pointer;
}

.modal-content input, .modal-content select {
    width: 100%;
    padding: 12px;
    margin-bottom: 12px;
    border-radius: 60px;
    border: 1px solid #e6dfd6;
}

#saveEditBtn {
    width: 100%;
    padding: 12px;
    background: #f5a623;
    border: none;
    border-radius: 60px;
    color: white;
    font-weight: bold;
    cursor: pointer;
}

@media (max-width: 800px) {
    .app-wrapper { flex-direction: column; }
    .sidebar { width: 100%; position: static; }
}
